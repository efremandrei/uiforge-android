<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.UiForge" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_cobalt</item>
        <item name="colorPrimaryVariant">@color/accent_cobalt</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSurface">@color/surface_primary</item>
        <item name="android:colorBackground">@color/surface_base</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@color/surface_base</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.UiForge.Dialog</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="ThemeOverlay.UiForge.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.UiForge.Dialog</item>
        <item name="colorSurface">@color/surface_primary</item>
        <item name="android:colorBackground">@color/surface_primary</item>
        <item name="android:textColorPrimary">@color/text_strong</item>
        <item name="android:textColorSecondary">@color/text_soft</item>
    </style>

    <style name="ShapeAppearance.UiForge.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
